# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key (bypasses RLS - keep this secret!)
# Found in: Project Settings > API > service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# LLM API Configuration (OpenAI-compatible)
# Works with any OpenAI-compatible provider: SiliconFlow, DeepSeek, Moonshot, etc.
LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_API_KEY=sk-your-key-here
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct
